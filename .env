# =========================================================================
# RECALL API CONFIGURATION
# =========================================================================

# --- 1. CLERK AUTHENTICATION ---
# Purpose: Manages user sign-in, sign-up, and session security.
# Source: https://dashboard.clerk.com/ -> Select Project -> "API Keys"
VITE_CLERK_PUBLISHABLE_KEY=pk_test_... # Client-side Publishable Key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_... # Sync with VITE_ key for Vercel/Next compatibility
CLERK_SECRET_KEY=sk_test_... # Secret Key (KEEP THIS PRIVATE)

# --- 2. VERCEL POSTGRES DATABASE ---
# Purpose: Stores your long-term memories and cognitive data.
# Source: https://vercel.com/ -> Your Project -> "Storage" tab -> "Postgres" -> .env.local
POSTGRES_URL="postgres://..." # Main database connection string
PRISMA_DATABASE_URL="postgres://..." # Duplicate of POSTGRES_URL for ORM compatibility

# --- 3. GOOGLE GEMINI AI ---
# Purpose: Powers the AI Chat, Memory Retrieval Logic, and Auto-tagging.
# Source: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=... # API Key from Google AI Studio

# =========================================================================
# NOTE: After adding these values, restart your development server.
# =========================================================================